{
  "name": "arcsend-sdk",
  "version": "1.0.1",
  "description": "SDK for chain-abstracted USDC transfers via ArcSend backend",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js",
      "default": "./dist/react/index.mjs"
    }
  },
  "files": [
    "dist",
    "python",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.19",
    "@types/react": "^18.3.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.5.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "axios": "^1.8.2",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
